# Core runtime
BUG_TRIAGE_AI_MODE=auto
BUG_TRIAGE_SEED=false

# Optional OpenAI integration
OPENAI_API_KEY=
OPENAI_TRIAGE_MODEL=gpt-5-mini
OPENAI_TESTGEN_MODEL=gpt-5.2

# Optional storage overrides
# Railway automatically provides RAILWAY_VOLUME_MOUNT_PATH for attached volumes.
# These overrides are only needed if you want a custom layout.
# BUG_TRIAGE_STORAGE_ROOT=/data
# BUG_TRIAGE_DB_PATH=/data/bug_triage.db
# BUG_TRIAGE_GENERATED_TESTS_DIR=/data/generated_tests
# BUG_TRIAGE_ARTIFACTS_DIR=/data/artifacts
